# Server
PORT=3000
NODE_ENV=production

# LLM Provider Selection
# Options: anthropic, openai, cohere, google
LLM_PROVIDER=openai

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Cohere
COHERE_API_KEY=your_cohere_api_key_here
COHERE_MODEL=command-r-plus

# Google (Gemini)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-pro

# Database (IconPlus - opcional, para salvar resultados)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=iconplus
DB_USER=root
DB_PASS=password

# API Security
API_KEY=your_api_key_here

# File Upload
MAX_FILE_SIZE=10485760

# Railway
RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=seu-dominio.up.railway.app  # injetada automaticamente pela Railway
